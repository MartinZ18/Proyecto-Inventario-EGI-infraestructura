# ============================================================
# Configuración del back-end de inventario (ITU)
# Copiar este archivo como .env y completar con valores reales.
# NUNCA subir el .env real al repositorio.
# ============================================================

# ----- App -----
APP_NAME=Inventario ITU
APP_ENV=local            # local | docker | k8s
DEBUG=true

# ----- Seguridad / JWT -----
# Generar uno nuevo con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambiar_esta_clave_por_una_aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ----- SQL Server (ubicaciones) -----
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DB=ubicacion_db
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=cambiar_password
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# ----- MongoDB (componentes) -----
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=inventario_db
MONGO_USER=admin
MONGO_PASSWORD=cambiar_password

# ----- LDAP / Active Directory -----
LDAP_HOST=localhost
LDAP_PORT=389
LDAP_BASE_DN=dc=itu,dc=local
LDAP_BIND_DN=svc-inventario@itu.local
LDAP_BIND_PASSWORD=cambiar_password
LDAP_USER_DN_TEMPLATE={username}@itu.local
LDAP_USE_SSL=false